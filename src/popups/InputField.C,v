@// InputField.C

#include "InputField.H"
#include "../env/TEnv.H"
#include "../env/TFont.H"
#include "../gfx/GBParent.H"
#include "../basics/Infty.H"

InputField::InputField(class GBParent *par, class Area const &area,
                       string const &initcont, class TFont &font0,
                       class PollServer &pserv, class TEnv &env0):
  GBox(par,area), Sleeper(pserv),
  reptascii(-1), nextrept(TTime::INFINITE_FUTURE),
  contents(initcont),
  cpos(0), xpos(0),
  cursorstate(0), nextcurs(TTime::CACHED),
  font(font0), env(env0) {
  baseliney=(area.h()-font.height())/2+font.ascent();
  }

void InputField::redraw(BBox const &bb) {
  font.setclip(bb);
  font.write(contents.c_str(),left(),top()+baseliney);
  if (cursorstate)
    font.write("_",left()+xpos,top()+baseliney+1);
  font.setclip(BBox(-INFTY,-INFTY,INFTY,INFTY));
  }

bool InputField::mouse(int button, bool ino, Point const &xy) {
  if (ino && button==1)
    { takefocus(); cursoronoff(0,0);
      string hoi=contents;
      int x=(xy.x()-left())>?0;
      while (font.stringwidth(hoi.c_str())>x)
        hoi.erase(hoi.size()-1,1);
      cpos=hoi.size();
      recalcxpos();
      cursoronoff();
      dbx(-980824,"IF:mouse: Taking focus");
    }
  return true;
  }

bool InputField::key(int keyc, bool ino) {
  if (!hasfocus())
    { dbx(-980824,"IF:key: no focus");
      return false;
    }
  int asc=env.lastchar();
  dbx(-980824,"IF:key(%i) %i -> %i",ino,keyc,asc);
  if (asc<32 || asc>255 || asc==127)
    { switch (asc)
        {
        case 8: case 13: case 127: break; // BS, Ret, Del
        case 256+8: case 256+9: break; // Left, Right
        case 512+8: case 512+9: break; // Home, End
        default: return false;
        }
    }
  if (ino)
    { reptascii=env.lastchar();
      nextrept=TTime(TTime::CACHED)+REPEAT_DELAY;
      sendreq(nextrept);
      key(reptascii);
    }
  else
    reptascii=-1;
  return true;
  }

bool InputField::offerfocus() {
  return false;
  return true;
  }

void InputField::forcedlosefocus() {
  if (cursorstate)
    cursoronoff(0,0);
  nextcurs=TTime(TTime::INFINITE_FUTURE);
  reptascii=-1;
  GBox::forcedlosefocus();
  }

void InputField::poll() {
  TTime t(TTime::CACHED);
  if (t>=nextrept && reptascii>=0)
    { key(reptascii); nextrept+=REPEAT_RATE; sendreq(nextrept); }
  if (t>=nextcurs)
    cursoronoff(!cursorstate);
  }

void InputField::key(int ascii) {
  bool done=false;
  bool redraw=false;
  dbx(-980824,"IF:key %i",ascii);
  dbx(-980824,"IF: before key: ct='%s'. cpos=%i",contents.c_str(),cpos);
  switch (ascii)
    {
    case 13: sendwarn(W_ENTER); losefocus(); forcedlosefocus(); return;
    case 8: // BS
      if (cpos>0)
        { contents.erase(--cpos,1); redraw=true; }
      break;
    case 127: // DEL
      if (cpos<contents.size())
        { contents.erase(cpos,1); redraw=true; }
      break;
    case 256+8: // Left
      if (cpos>0)
        { cursoronoff(0,0); cpos--; done=true; }
      break;
    case 256+9: // Right
      if (cpos<contents.size())
        { cursoronoff(0,0); cpos++; done=true; }
      break;
    case 512+8: // Home
      if (cpos!=0)
        { cursoronoff(0,0); cpos=0; done=true; }
      break;
    case 512+9: // End
      if (cpos<contents.size())
        { cursoronoff(0,0); cpos=contents.size(); done=true; }
      break;
    default:
      if (ascii>=32 && ascii<256 && ascii!=127)
        { string tmp("_"); tmp+=char(ascii);
          if (font.stringwidth(contents.c_str())<
              width()-font.stringwidth(tmp.c_str()))
            { cursoronoff(0,0);
              contents.insert(cpos++,1,ascii);
              drawrest(); done=true;
            }
        }
      break;
    }
  dbx(-980824,"IF: after key: ct='%s'. cpos=%i",contents.c_str(),cpos);
  if (done || redraw)
    { recalcxpos(); cursoronoff(); }
  if (redraw)
    drawrest();
  }

void InputField::cursoronoff(bool on, bool alarm) {
  cursorstate=on;
  if (alarm)
    { nextcurs=TTime(TTime::CACHED) + CURSOR_BLINK_DELAY;
      sendreq(nextcurs);
    }
  parent()->redraw(BBox(left()+xpos,top()+baseliney+1,
                        left()+xpos+font.stringwidth("_"),bottom()));
  }

void InputField::recalcxpos() {
  string tmp(contents,0,cpos);
  xpos=font.stringwidth(tmp.c_str());
  }

void InputField::drawrest() {
  parent()->redraw(BBox(left()+xpos,top(),right(),bottom()));
  }
