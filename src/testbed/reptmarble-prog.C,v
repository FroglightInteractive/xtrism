@// prog.C - main part of testbed: user editable
// This vsn fills the entire screen with a repeatable marble block.
// init() constructs such a block from a normal marble block,
// and tpoll() rather clumsily plots it to the screen.

// Define your globals here. Static please.

#include "main.H"

#include "../bricks/brickcell.H"

BrickCell *bc;

int lasty;

const int WIDTH=224;
const int HEIGHT=128;

unsigned int THP::init() {
  // Initialise your globals now
  bc=new BrickCell(2*WIDTH,2*HEIGHT);
  for (int y=0; y<2*HEIGHT; y++)
    for (int x=0; x<WIDTH; x++)
      bc->c(x,y)=(bc->cc(x,y)*x+bc->cc(WIDTH+x,y)*(WIDTH-x))/WIDTH;
  for (int x=0; x<WIDTH; x++)
    for (int y=0; y<HEIGHT; y++)
      bc->c(x,y)=(bc->cc(x,y)*y+bc->cc(x,HEIGHT+y)*(HEIGHT-y))/HEIGHT;
  lasty=0;
  return 0;
  }

void THP::tpoll() {
  if (lasty<(int)testbed.rgbmap.height())
    { int newy=(lasty+HEIGHT)<?testbed.rgbmap.height();
      int wid=testbed.rgbmap.width();
      for (int y=lasty; y<newy; y++)
        for (int x=0; x<wid; x++)
          { int G=bc->cc(x%(WIDTH),y%(HEIGHT));
//            printf("%i ",G);
            testbed.rgbmap.set(x,y,-16+G/4,-16+G/4,100+G/4);
          }
      done(BBox(0,lasty, (int)testbed.rgbmap.width(), newy));
      lasty=newy;
    }
  }
