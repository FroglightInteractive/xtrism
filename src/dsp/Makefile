OBJS = Sample.o SPlayer.o
DEBUG = -g

SRCS =	*.C
INCS =	$(R6XINCDIR) -I/usr/include/g++
# DEBUG =
# DEBUG = -g

R6XINCDIR = -I/usr/X11R6/include

CFLAGS = ${DEBUG} -Wall -W  -c ${PROFILE}

lib.a: lib.a($(OBJS))

depend: $(SRCS)
	makedepend -Y -- $(CFLAGS) -- $(SRCS) 2> /dev/null

(%.o):	%.o
	ar cr $@ $<
%.o:	%.c
	@echo -e '\n$<'
	gcc $(CFLAGS) -o $@ $< $(INCS)
%.o:	%.C
	@echo -e '\n$<'
	g++ $(CFLAGS) -o $@ $< $(INCS)

